  "keyFeatures": [
    "SNAG (Social Network Augmented Generation) engine",
    "Five temporal modes: FORWARD, PORTAL, BRANCHING, CYCLICAL, DIRECTORIAL",
    "Heterogeneous fidelity resolution (TENSOR_ONLY to TRAINED)",
    "Knowledge provenance tracking with exposure events",
    "Per-character dialog synthesis with voice discipline",
    "19 composable mechanisms for social simulation",
    "Query-driven lazy resolution for cost optimization",
    "Training data export in TDF, JSONL, SQLite, Fountain formats",
    "FastAPI REST API with rate limiting and usage quotas",
    "Convergence validation for causal graph reliability"
  ],
  "publicApiSurface": [
    "./run.sh list - List all simulation templates",
    "./run.sh run <template> - Execute simulation template",
    "./run.sh run --category showcase - Run by category",
    "cli.py - Hydra CLI with autopilot, train, evaluate, interactive modes",
    "POST /api/simulations/submit - Submit simulation job",
    "GET /api/simulations/{job_id} - Get simulation status",
    "GET /api/data-export/{run_id} - Export simulation artifacts",
    "GET /api/tensors/{entity_id} - Retrieve entity tensor",
    "POST /api/search/semantic - Semantic search across entities",
    "POST /api/batch/submit - Submit batch simulation",
    "Orchestrator.run() - Main orchestration engine",
    "LLMClient.from_hydra_config() - Centralized LLM service",
    "GraphStore - SQLite persistence layer",
    "create_entity_training_workflow() - LangGraph workflow factory",
    "build_temporal_chain() - Temporal chain builder",
    "QueryInterface.query() - Natural language query interface",
    "Validator.validate_all() - Comprehensive validation suite",
    "PortalStrategy.run() - Backward reasoning from target state",
    "BranchingStrategy.run() - Counterfactual timeline generation",
    "TensorCompressor.compress() - TTM tensor compression"
